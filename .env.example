# ============================================
# Bot (FastAPI) — Railway Deployment
# Copy to .env for local dev or set as
# Railway Environment Variables in the dashboard.
# ============================================

# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=aot_analyzer_bot

# TradingView API (RapidAPI)
TRADINGVIEW_API_KEY=your_rapidapi_key
TRADINGVIEW_API_HOST=tradingview-data1.p.rapidapi.com

# Firebase Admin SDK (use service account JSON file path)
FIREBASE_CREDENTIALS_PATH=../your-service-account.json
# OR individual fields (if not using JSON file):
FIREBASE_PROJECT_ID=aot-analyzer-bot
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@aot-analyzer-bot.iam.gserviceaccount.com

# NVIDIA NIM API
NVIDIA_NIM_API_KEY=nvapi-your_nvidia_key
NVIDIA_MODEL_PROCESSOR=meta/llama-3.1-8b-instruct
NVIDIA_MODEL_VISION=meta/llama-3.2-11b-vision-instruct
NVIDIA_MODEL_STRATEGIST=meta/llama-3.3-70b-instruct

# Bot Environment
BOT_ENV=production
DEBUG=False
LOG_LEVEL=INFO

# Dashboard URL (for /dashboard command)
DASHBOARD_URL=https://analyzer-dashboard-kohl.vercel.app

# Screenshot Settings
MAX_SCREENSHOT_SIZE_MB=10
SCREENSHOT_CACHE_MINUTES=5
VERIFICATION_THRESHOLD_SCORE=60
CONFIDENCE_BOOST_HIGH=15
CONFIDENCE_BOOST_MEDIUM=5
CONFIDENCE_PENALTY=10
